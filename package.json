{
  "name": "avail",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/auth-service",
    "packages/groups-service",
    "packages/status-service",
    "packages/notification-service",
    "packages/websocket-service",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/auth-service\" \"npm run dev -w packages/groups-service\" \"npm run dev -w packages/status-service\" \"npm run dev -w packages/notification-service\" \"npm run dev -w packages/websocket-service\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "npm run prisma migrate dev -w packages/shared",
    "db:seed": "npm run prisma db seed -w packages/shared",
    "db:generate": "npm run prisma generate -w packages/shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
