# Auth Service — Local environment
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

NODE_ENV=development
PORT=3001

# Database (Docker Compose default)
DATABASE_URL=postgresql://avail:avail_local@localhost:5432/avail
DIRECT_URL=postgresql://avail:avail_local@localhost:5432/avail

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# JWT — RS256 asymmetric keys
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the PEM contents here, replacing actual newlines with \n
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_EXPIRY=15m

# Firebase (for Apple + Google sign-in)
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# AWS (for SMS OTP)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_SECRET
AWS_SNS_SENDER_ID=Avail
