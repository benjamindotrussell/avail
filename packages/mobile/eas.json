{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    },
    "simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.19.4",
      "env": {
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
