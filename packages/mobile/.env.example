# Mobile — environment variables
# Copy to .env.local — never commit .env.local

# Staging API
EXPO_PUBLIC_WS_URL=wss://api-staging.avail.app

# Google Sign-In — Firebase console > Authentication > Sign-in method > Google > Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Local dev (uncomment when running backend locally via docker-compose)
# Replace 192.168.x.x with your machine's LAN IP (run: ipconfig | find "IPv4")
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
# EXPO_PUBLIC_WS_URL=ws://192.168.x.x:3000
