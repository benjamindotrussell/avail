# Notification Service — Local environment
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

NODE_ENV=development
PORT=3004

# Database (Docker Compose default)
DATABASE_URL=postgresql://avail:avail_local@localhost:5432/avail
DIRECT_URL=postgresql://avail:avail_local@localhost:5432/avail

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# JWT — RS256 public key (verify-only)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_EXPIRY=15m

# Firebase (for FCM + APNs via Firebase Admin SDK)
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
