# Groups Service — Local environment
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

NODE_ENV=development
PORT=3002

# Database (Docker Compose default)
DATABASE_URL=postgresql://avail:avail_local@localhost:5432/avail
DIRECT_URL=postgresql://avail:avail_local@localhost:5432/avail

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# JWT — RS256 public key (verify-only, never the private key)
# Must match the public key used by auth-service
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_EXPIRY=15m

# Invite link base URL
INVITE_BASE_URL=https://avail.app/join
